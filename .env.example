# =============================================================================
# Bharadwaja Seva Sangham — environment variables
# =============================================================================
# Copy this file to `.env` and fill in real values for local development.
# `.env` is gitignored — NEVER commit real secrets.
#
# For deployment (Vercel / Render / Railway / etc), set these in the host's
# secret/environment manager — do NOT upload a .env file.
# =============================================================================

# ---- Database (required) -----------------------------------------------------
# External PostgreSQL connection string (used by the API server and migrations).
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
EXTERNAL_DATABASE_URL=postgres://user:password@host:5432/bharadwaja_seva

# ---- Admin login (required) --------------------------------------------------
# Credentials for the /admin login page.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# ---- Session security (required) ---------------------------------------------
# Long random string used to sign admin session cookies.
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-32+-random-bytes

# ---- Runtime ------------------------------------------------------------------
# "development" enables verbose logging and disables secure cookies.
# Set to "production" in any deployed environment.
NODE_ENV=development

# Optional: pino log level (trace | debug | info | warn | error). Default: info
# LOG_LEVEL=info

# ---- API server port (required by the dev workflow) --------------------------
# In production the host (Vercel/Render/etc) usually injects PORT automatically.
PORT=8080

# ---- Frontend base path (Vite) -----------------------------------------------
# Path prefix the frontend is served from. "/" for a normal Vercel deployment.
# Replit's shared proxy serves it from "/", so leave as "/" unless you nest it.
BASE_PATH=/

# =============================================================================
# Photo uploads / object storage
# =============================================================================
# The current implementation uses Replit App Storage (a Google Cloud Storage
# bucket managed by Replit). These env vars only work INSIDE Replit.
#
# To deploy on Vercel (or anywhere outside Replit), you must either:
#   (a) Disable photo uploads, or
#   (b) Switch artifacts/api-server/src/lib/objectStorage.ts to use your own
#       S3-compatible bucket (AWS S3, Cloudflare R2, Supabase Storage, etc.)
#       and rewrite the env vars below accordingly.
#
# Replit-only (will be empty / non-functional outside Replit):
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=

# =============================================================================
# Optional: Gemini AI (for the one-off translation scripts)
# =============================================================================
# Only needed if you re-run lib/db translation scripts. Not required at runtime.
# Inside Replit these are auto-provisioned by the AI Integrations skill.
# Outside Replit, get a key from https://aistudio.google.com/app/apikey and use
# the public endpoint:
#   AI_INTEGRATIONS_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
#   AI_INTEGRATIONS_GEMINI_API_KEY=your-gemini-api-key
AI_INTEGRATIONS_GEMINI_BASE_URL=
AI_INTEGRATIONS_GEMINI_API_KEY=
